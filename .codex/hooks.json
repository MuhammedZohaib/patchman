{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'node \"$(git rev-parse --show-toplevel)/hooks/session-prime.js\"'",
            "timeout": 5,
            "statusMessage": "Patchman: loading defensive review posture"
          },
          {
            "type": "command",
            "command": "bash -c 'node \"$(git rev-parse --show-toplevel)/hooks/framework-detector.js\"'",
            "timeout": 5,
            "statusMessage": "Patchman: detecting framework signals"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'node \"$(git rev-parse --show-toplevel)/hooks/review-mode-tracker.js\"'",
            "timeout": 5,
            "statusMessage": "Patchman: classifying review mode"
          }
        ]
      }
    ]
  }
}
